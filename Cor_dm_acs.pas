procedure TdmCor.FacLoadingsSmpPostError(DataSet: TDataSet; E: EDatabaseError;
  var Action: TDataAction);
begin
  MessageDlg('Key violation - duplicate combination of Coran type, Group and Sample',
            mtWarning,[mbOK],0);
  dmCor.FacLoadingsSmp.CancelUpdates;
end;

procedure TdmCor.CoranVecLinkedPostError(DataSet: TDataSet;
  E: EDatabaseError; var Action: TDataAction);
begin
  MessageDlg('Key violation - duplicate combination of Coran type, Group and Sample',
            mtWarning,[mbOK],0);
  dmCor.CoranVecLinked.CancelUpdates;
end;

procedure TdmCor.CoranChem1PostError(DataSet: TDataSet; E: EDatabaseError;
  var Action: TDataAction);
begin
  MessageDlg('Key violation - probably duplicate combination of Group and Sample',
            mtWarning,[mbOK],0);
  dmCor.CoranChem.CancelUpdates;
end;

procedure TdmCor.GroupedSmpPostError(DataSet: TDataSet; E: EDatabaseError;
  var Action: TDataAction);
begin
  MessageDlg('Key violation - probably duplicate combination of Group and Sample',
            mtWarning,[mbOK],0);
  Abort;
end;


